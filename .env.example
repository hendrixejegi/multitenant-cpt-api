# Copy this to `.env` and fill values before running the app

# PostgreSQL connection string (do NOT commit the real value)
DATABASE_URL=postgresql://<USER>:<PASSWORD>@<HOST>:5432/<DATABASE>?sslmode=require&channel_binding=require

# JWT settings
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# Bcrypt rounds for password hashing
BCRYPT_ROUNDS=10

# Server
PORT=3000
NODE_ENV=development

# CORS origins (comma separated)
ALLOWED_ORIGINS=http://localhost:3000
